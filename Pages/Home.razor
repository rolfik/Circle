@page "/"
@inject IStringLocalizer<AppStrings> L
@inject ContentManager ContentManager
@inject SettingsService Settings
@implements IDisposable

<CircularCurtain Fullscreen="@IsFullscreen">
    @if (CurrentContentUrl is not null)
    {
        if (IsPulsing)
        {
            <div class="page-pulse" style="@PulseStyle">
                <Page ContentUrl="@CurrentContentUrl" Transition="@CurrentTransition" />
            </div>
        }
        else
        {
            <Page ContentUrl="@CurrentContentUrl" Transition="@CurrentTransition" />
        }
    }
</CircularCurtain>

@code {
    /// <summary>
    /// Effective PageContent for rendering: current page if any, otherwise the first
    /// circle's own content (implicit landing content).
    /// </summary>
    private Models.PageContent? EffectiveContent =>
        ContentManager.CurrentPage?.Content
        ?? ContentManager.Circles.FirstOrDefault()?.Content;

    private string? CurrentContentUrl => EffectiveContent?.ResolvedPath;

    private bool IsFullscreen => EffectiveContent?.FullScreen ?? false;

    private PageTransition CurrentTransition =>
        EffectiveContent?.Transition ?? PageTransition.Fade;

    private double PulseMinScale => EffectiveContent?.PulseMinScale ?? 1.0;

    /// <summary>
    /// Pulse only when the curtain is visible (not fullscreen), it is actually rotating
    /// (RotationSeconds &gt; 0) and the content opts in via PulseMinScale &lt; 1.
    /// </summary>
    private bool IsPulsing =>
        EffectiveContent is not null
        && !IsFullscreen
        && Settings.RotationSeconds > 0
        && PulseMinScale < 1.0
        && PulseMinScale > 0.0;

    private string? PulseStyle =>
        IsPulsing
            ? $"--pulse-duration:{Settings.RotationSeconds.ToString(System.Globalization.CultureInfo.InvariantCulture)}s;"
              + $"--pulse-min-scale:{PulseMinScale.ToString(System.Globalization.CultureInfo.InvariantCulture)};"
            : null;

    protected override void OnInitialized()
    {
        ContentManager.OnStateChanged += StateHasChanged;
        Settings.OnChanged += StateHasChanged;
    }

    public void Dispose()
    {
        ContentManager.OnStateChanged -= StateHasChanged;
        Settings.OnChanged -= StateHasChanged;
    }
}
