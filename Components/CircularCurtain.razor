@namespace Circle.Components
@inject HttpClient Http
@inject SettingsService Settings
@inject ContentManager ContentManager
@implements IDisposable

<div class="curtain-container @(Fullscreen ? "curtain-fullscreen" : null)"
     style="@ContainerStyle">
    <div class="curtain-content">
        @ChildContent
    </div>

    @if (_svgMarkup is not null)
    {
        <div class="curtain-svg @(IsRotating ? "curtain-rotating" : null)">
            @_svgMarkup
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Fullscreen { get; set; }

    private MarkupString? _svgMarkup;
    private string? _loadedCurtainPath;

    private bool IsRotating => Settings.RotationSeconds > 0;

    private string ContainerStyle =>
        IsRotating
            ? $"--curtain-rot-duration:{Settings.RotationSeconds.ToString(System.Globalization.CultureInfo.InvariantCulture)}s;"
              + $"--curtain-rot-direction:{(Settings.RotationDirection >= 0 ? "normal" : "reverse")};"
            : string.Empty;

    protected override void OnInitialized()
    {
        Settings.OnChanged += OnSettingsChanged;
        ContentManager.OnStateChanged += OnContentChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCurtainAsync();
    }

    private async Task LoadCurtainAsync()
    {
        // Pick the curtain SVG from the current circle, falling back to the first declared circle
        // (so the home/default state still shows a curtain before any selection is made).
        var path = ContentManager.CurrentCircle?.CurtainPath
                   ?? ContentManager.Circles.FirstOrDefault()?.CurtainPath;
        if (path is null || path == _loadedCurtainPath) return;
        try
        {
            var svgText = await Http.GetStringAsync(path);
            _svgMarkup = new MarkupString(svgText);
            _loadedCurtainPath = path;
            StateHasChanged();
        }
        catch
        {
            // Leave previous curtain (if any) in place on transient load errors.
        }
    }

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    private void OnContentChanged() => InvokeAsync(LoadCurtainAsync);

    public void Dispose()
    {
        Settings.OnChanged -= OnSettingsChanged;
        ContentManager.OnStateChanged -= OnContentChanged;
    }
}
